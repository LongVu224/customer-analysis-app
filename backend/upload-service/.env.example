# Azure Storage Configuration
# Storage account name is required
STORAGE_NAME=your_storage_account_name

# Storage key is OPTIONAL - if not provided, the app will use Azure Identity
# (DefaultAzureCredential) which supports:
#   - Managed Identity (in Azure)
#   - Azure CLI credentials (local development)
#   - Environment variables (AZURE_CLIENT_ID, AZURE_TENANT_ID, AZURE_CLIENT_SECRET)
# STORAGE_KEY=your_storage_account_key

# Optional: Override the storage URL (defaults to https://{STORAGE_NAME}.blob.core.windows.net)
# STORAGE_URL=https://your_storage_account.blob.core.windows.net

# MongoDB Connection
DB_CONNECTION_STRING=mongodb://localhost:27017/sale-analysis

# Upload Password Protection (optional - leave empty for no protection)
UPLOAD_PASSWORD=your_secure_password
