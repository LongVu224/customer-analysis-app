# Azure Key Vault Configuration
# Key Vault name is required - secrets are fetched from here at startup
KEY_VAULT_NAME=your_keyvault_name

# The app uses Azure Identity (DefaultAzureCredential) which supports:
#   - Managed Identity (in Azure)
#   - Azure CLI credentials (local development: run `az login`)
#   - Environment variables (AZURE_CLIENT_ID, AZURE_TENANT_ID, AZURE_CLIENT_SECRET)

# Server port (optional)
PORT=8999

# Service endpoints for health checks (optional - defaults shown)
# UPLOAD_SERVICE_URL=http://localhost:8000
# UPLOAD_SERVICE_DISPLAY_URL=http://localhost:8000
# INSIGHTS_SERVICE_URL=http://localhost:9000
# INSIGHTS_SERVICE_DISPLAY_URL=http://localhost:9000
# INVESTMENT_SERVICE_URL=http://localhost:3004
# INVESTMENT_SERVICE_DISPLAY_URL=http://localhost:3004

# Secrets stored in Azure Key Vault (fetched at runtime):
#   - db-connection-string: MongoDB connection string
